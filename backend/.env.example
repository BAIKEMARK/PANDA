# ==================== 应用基础配置 ====================
APP_NAME=PANDA - 围产期抑郁管理智能培训系统
APP_VERSION=0.1.0
DEBUG=True

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_DIR=logs
LOG_TO_CONSOLE=True
LOG_MAX_BYTES_KB=1024
LOG_BACKUP_DAYS=30

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=panda
DB_CHARSET=utf8mb4

# 数据库连接池配置
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ==================== JWT认证配置 ====================
# 重要：生产环境必须修改为强密钥
SECRET_KEY=your-secret-key-change-in-production-use-strong-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==================== AI模型配置 ====================
AI_TEXT_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AI_TEXT_KEY=sk-your-api-key-here
AI_TEXT_MODEL=qwen-max

# LLM 高级配置
LLM_MAX_RETRIES=3
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.7
LLM_STREAMING=False

# ==================== Redis配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_DECODE_RESPONSES=True
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_MAX_CONNECTIONS=50

# ==================== CORS配置 ====================
CORS_ORIGINS_STR=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175

# ==================== 性能配置 ====================
# API限流配置（可选）
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=60

# 缓存配置
CACHE_ENABLED=True
CACHE_DEFAULT_TTL=300

# ==================== 安全配置 ====================
# CSRF保护（可选）
CSRF_ENABLED=False
CSRF_SECRET=your-csrf-secret-here

# ==================== 监控配置 ====================
# Prometheus监控（可选）
PROMETHEUS_ENABLED=False
PROMETHEUS_PORT=9090

# ==================== 其他配置 ====================
# 时区设置
TIMEZONE=Asia/Shanghai
